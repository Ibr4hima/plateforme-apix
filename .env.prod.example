# ── Base de données ───────────────────────────────────────────────────────────
POSTGRES_DB=apix_production
POSTGRES_USER=apix_user
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGEME_LONG_RANDOM_STRING
DEBUG=false
# Origines CORS autorisées (votre domaine frontend, séparées par virgule)
ALLOWED_ORIGINS=https://votre-domaine.apix.sn

# Même valeur que AUTH_SECRET côté frontend — utilisé pour valider les JWT
AUTH_SECRET=CHANGEME_SAME_AS_FRONTEND_AUTH_SECRET

# Admins : liste des emails ayant le rôle admin (séparés par virgule)
ADMIN_EMAILS=votre.email@apix.sn

# UNCTAD (optionnel — auto-refresh données IDE)
UNCTAD_CLIENT_ID=
UNCTAD_CLIENT_SECRET=

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL publique de l'API (accessible depuis le navigateur)
NEXT_PUBLIC_API_URL=https://votre-domaine.apix.sn/api/v1

# URL publique du frontend (pour les callbacks OAuth)
NEXTAUTH_URL=https://votre-domaine.apix.sn

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID=PLACEHOLDER_AZURE_CLIENT_ID
AZURE_AD_CLIENT_SECRET=PLACEHOLDER_AZURE_CLIENT_SECRET
AZURE_AD_TENANT_ID=PLACEHOLDER_AZURE_TENANT_ID

# ── Caddy (reverse proxy HTTPS) ───────────────────────────────────────────────
DOMAIN=votre-domaine.apix.sn

# ── pgAdmin (optionnel — ne pas exposer en production) ────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@apix.sn
PGADMIN_DEFAULT_PASSWORD=CHANGEME
