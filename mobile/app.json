{
  "expo": {
    "name": "APIX Sénégal",
    "slug": "apix-senegal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "apix",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "sn.apix.plateforme",
      "supportsTablet": true,
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "package": "sn.apix.plateforme",
      "adaptiveIcon": {
        "backgroundColor": "#004f91",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "splash": {
      "backgroundColor": "#004f91",
      "resizeMode": "contain",
      "image": "./assets/images/splash-icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
