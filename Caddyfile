{$DOMAIN} {
    # Accès démo protégé par mot de passe (basic-auth) : toute personne ayant le
    # lien saisit les identifiants (fournis via secrets.caddy.env). La navigation
    # est ensuite libre — le contrôle par compte de la plateforme est désactivé
    # tant que AUTH_ENFORCED=false (mode démo ouverte).
    basic_auth {
        {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
    }

    # L'API backend est servie sous /api/v1/* uniquement. On ne route QUE ce
    # préfixe vers FastAPI : les routes NextAuth (/api/auth/*) doivent rester
    # sur le frontend Next.js, sinon Caddy les enverrait au backend (404).
    reverse_proxy /api/v1/* backend:8000
    reverse_proxy /* frontend:3000
}
