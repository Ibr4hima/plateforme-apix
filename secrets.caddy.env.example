# Identifiants d'accès à la démo (basic-auth Caddy).
# Copier ce fichier en « secrets.caddy.env » sur le VPS et renseigner les valeurs.
#
# Générer le fichier complet (le hash bcrypt contient des « $ » que Docker Compose
# interprète comme des variables — il faut les DOUBLER, « $ » → « $$ ») :
#
#   HASH=$(docker run --rm caddy:2-alpine caddy hash-password --plaintext 'TON_MOT_DE_PASSE')
#   ESC=$(printf '%s' "$HASH" | sed 's/\$/$$/g')
#   printf 'BASIC_AUTH_USER=apix\nBASIC_AUTH_HASH=%s\n' "$ESC" > secrets.caddy.env
#
# (Si tu colles le hash à la main, double chaque « $ » : $2a$14$... → $$2a$$14$$...)

BASIC_AUTH_USER=apix
BASIC_AUTH_HASH=REMPLACER_PAR_LE_HASH_BCRYPT_AVEC_DOLLARS_DOUBLES
