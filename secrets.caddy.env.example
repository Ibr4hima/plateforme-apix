# Identifiants d'accès à la démo (basic-auth Caddy).
# Copier ce fichier en « secrets.caddy.env » sur le VPS et renseigner les valeurs.
#
# Générer le hash bcrypt du mot de passe :
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'TON_MOT_DE_PASSE'
#
# Coller le hash obtenu dans BASIC_AUTH_HASH (les « $ » doivent rester tels quels,
# ne PAS les échapper : ce fichier est lu via env_file, sans interpolation Compose).

BASIC_AUTH_USER=apix
BASIC_AUTH_HASH=REMPLACER_PAR_LE_HASH_BCRYPT
