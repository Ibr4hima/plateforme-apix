# ── Assistant IA (API Claude / Anthropic) ────────────────────────────────────
# Clé API obtenue sur https://console.anthropic.com (côté serveur uniquement,
# jamais exposée au frontend). Laisser vide désactive l'assistant.
ANTHROPIC_API_KEY=

# Réglages optionnels (valeurs par défaut dans app/core/config.py) :
# ASSISTANT_MODELE=claude-sonnet-5     # ou claude-opus-4-8 pour + de finesse
# ASSISTANT_MAX_TOKENS=1500            # plafond de sortie par réponse
# ASSISTANT_RATE_LIMIT=20              # requêtes par IP et par fenêtre
# ASSISTANT_RATE_FENETRE=3600          # fenêtre du rate-limit (secondes)
